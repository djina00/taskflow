<Window x:Class="TaskFlow.Desktop.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="TaskFlow — Create account" Height="560" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="{StaticResource BgBrush}">
    <Grid>
        <Border Style="{StaticResource Card}" Width="340" VerticalAlignment="Center"
                HorizontalAlignment="Center" Padding="28">
            <StackPanel>
                <TextBlock Text="TaskFlow" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="Create your account" Style="{StaticResource Muted}"
                           HorizontalAlignment="Center" Margin="0,2,0,18" />

                <TextBlock Text="Full name" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Email" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Password" Style="{StaticResource FieldLabel}" />
                <PasswordBox x:Name="PasswordInput" />

                <Button Content="Create account" Style="{StaticResource PrimaryButton}"
                        Command="{Binding RegisterCommand}" Margin="0,20,0,0" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                    <TextBlock Text="Already have an account?" Style="{StaticResource Muted}"
                               VerticalAlignment="Center" />
                    <Button Content="Sign in" Command="{Binding GoToLoginCommand}"
                            Style="{StaticResource LinkButton}" Margin="6,0,0,0" />
                </StackPanel>

                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusText}"
                           Foreground="#DC2626" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
