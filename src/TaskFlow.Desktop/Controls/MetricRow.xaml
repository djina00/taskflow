<UserControl x:Class="TaskFlow.Desktop.Controls.MetricRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <DockPanel>
        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                   Text="{Binding Value, ElementName=Root}" Style="{StaticResource MetricValue}" />
        <TextBlock Text="{Binding Label, ElementName=Root}" Style="{StaticResource MetricLabel}" />
    </DockPanel>
</UserControl>
