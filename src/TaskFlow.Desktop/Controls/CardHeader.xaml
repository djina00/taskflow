<UserControl x:Class="TaskFlow.Desktop.Controls.CardHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <DockPanel>
        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                Content="{Binding ActionText, ElementName=Root}"
                Command="{Binding ActionCommand, ElementName=Root}">
            <Button.Style>
                <!-- Inherit the themed button, but hide the action entirely when no command is supplied. -->
                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ActionCommand, ElementName=Root}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        <TextBlock Text="{Binding Title, ElementName=Root}" Style="{StaticResource H2}" VerticalAlignment="Center" />
    </DockPanel>
</UserControl>
