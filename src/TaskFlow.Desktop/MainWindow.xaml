<Window x:Class="TaskFlow.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:TaskFlow.Desktop.Views"
        mc:Ignorable="d"
        Title="TaskFlow" Height="620" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderBrush}" Padding="20,12">
            <DockPanel>
                <TextBlock Text="TaskFlow" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,12,0"
                               Text="{Binding Session.CurrentUserName, StringFormat='Signed in as {0}'}" />
                    <Button Content="Sign out" Command="{Binding SignOutCommand}" Padding="12,5" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl Margin="12,8,12,12">
            <TabItem Header="Projects">
                <views:ProjectsView DataContext="{Binding Projects}" />
            </TabItem>
            <TabItem Header="Tasks">
                <views:TasksView DataContext="{Binding Tasks}" />
            </TabItem>
            <TabItem Header="Notifications">
                <views:NotificationsView DataContext="{Binding Notifications}" />
            </TabItem>
            <TabItem Header="Reports">
                <views:ReportsView DataContext="{Binding Reports}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
