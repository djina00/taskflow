<UserControl x:Class="TaskFlow.Desktop.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="860" d:DesignHeight="460">
    <Border Style="{StaticResource Card}" Margin="4" Padding="16,14">
        <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Notifications" Style="{StaticResource H2}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding Status}" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="Mark read" Command="{Binding MarkReadCommand}" Margin="0,0,8,0" />
                    <Button Content="Refresh" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}" />
                </StackPanel>
            </DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Sign in to see your notifications." Style="{StaticResource Muted}"
                       Margin="0,0,0,8"
                       Visibility="{Binding Session.IsLoggedIn, Converter={StaticResource InverseBoolToVisibility}}" />
            <DataGrid ItemsSource="{Binding Notifications}" SelectedItem="{Binding SelectedNotification}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="130" />
                    <DataGridTextColumn Header="MESSAGE" Binding="{Binding Message}" Width="*" />
                    <DataGridCheckBoxColumn Header="READ" Binding="{Binding IsRead}" Width="60" />
                    <DataGridTextColumn Header="CREATED (UTC)" Binding="{Binding CreatedOnUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
