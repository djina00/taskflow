<UserControl x:Class="TaskFlow.Desktop.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:TaskFlow.Desktop.Controls"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="860" d:DesignHeight="460">
    <Border Style="{StaticResource Card}" Margin="4" Padding="16,14">
        <DockPanel>
            <ctrl:CardHeader DockPanel.Dock="Top" Title="Notifications"
                             ActionCommand="{Binding RefreshCommand}" Margin="{StaticResource SectionMargin}" />
            <TextBlock DockPanel.Dock="Top" Text="Sign in to see your notifications." Style="{StaticResource Muted}"
                       Margin="0,0,0,8"
                       Visibility="{Binding Session.IsLoggedIn, Converter={StaticResource InverseBoolToVisibility}}" />
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Mark read" Style="{StaticResource PrimaryButton}" Command="{Binding MarkReadCommand}" Margin="0,0,12,0" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource Muted}" VerticalAlignment="Center" />
            </StackPanel>
            <DataGrid ItemsSource="{Binding Notifications}" SelectedItem="{Binding SelectedNotification}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="130" />
                    <DataGridTextColumn Header="MESSAGE" Binding="{Binding Message}" Width="*" />
                    <DataGridCheckBoxColumn Header="READ" Binding="{Binding IsRead}" Width="60" />
                    <DataGridTextColumn Header="CREATED (UTC)" Binding="{Binding CreatedOnUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Border>
</UserControl>
