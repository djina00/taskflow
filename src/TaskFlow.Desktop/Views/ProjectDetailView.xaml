<UserControl x:Class="TaskFlow.Desktop.Views.ProjectDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:TaskFlow.Desktop.Controls">
    <StackPanel Width="380">
        <TextBlock Text="Edit project" Style="{StaticResource H2}" />

        <Border Style="{StaticResource Divider}" />

        <ctrl:LabeledField Label="Name">
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
        </ctrl:LabeledField>
        <ctrl:LabeledField Label="Description">
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto" />
        </ctrl:LabeledField>

        <Border Style="{StaticResource Divider}" />

        <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Right" Content="Close" Command="{Binding CloseCommand}" Margin="8,0,0,0" />
            <Button DockPanel.Dock="Right" Content="Save changes" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}" />
        </DockPanel>
        <TextBlock Text="{Binding Status}" Style="{StaticResource StatusText}" Foreground="{StaticResource ErrorBrush}" />
    </StackPanel>
</UserControl>
