<UserControl x:Class="TaskFlow.Desktop.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="860" d:DesignHeight="460">
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="New project" Style="{StaticResource H2}" />
                <TextBlock Text="Name" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Description" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="64" VerticalScrollBarVisibility="Auto" />
                <Button Content="Create project" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateCommand}" Margin="0,16,0,0" />
                <TextBlock Text="Sign in to create projects." Style="{StaticResource Muted}" Margin="0,8,0,0"
                           Visibility="{Binding Session.IsLoggedIn, Converter={StaticResource InverseBoolToVisibility}}" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusText}" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16,14">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Projects" Style="{StaticResource H2}" VerticalAlignment="Center" />
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" />
                </DockPanel>
                <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Muted}" Margin="2,8,0,0"
                           Text="{Binding Session.SelectedProjectName, StringFormat='Selected project: {0} — open the Tasks tab'}"
                           Visibility="{Binding Session.HasSelectedProject, Converter={StaticResource BoolToVisibility}}" />
                <DataGrid ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="MEMBERS" Binding="{Binding Members.Count}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
