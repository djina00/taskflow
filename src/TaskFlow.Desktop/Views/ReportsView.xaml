<UserControl x:Class="TaskFlow.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="860" d:DesignHeight="460">
    <UserControl.Resources>
        <Style x:Key="Metric" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="4">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Reports" Style="{StaticResource H1}" VerticalAlignment="Center" />
            <Button Content="Refresh" Style="{StaticResource PrimaryButton}" Command="{Binding RefreshCommand}"
                    DockPanel.Dock="Right" HorizontalAlignment="Right" />
        </DockPanel>

        <Grid VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="{Binding Session.SelectedProjectName, StringFormat='Project — {0}'}" Style="{StaticResource H2}" />
                    <TextBlock Text="Select a project on the Projects tab." Style="{StaticResource Muted}" Margin="0,8,0,0"
                               Visibility="{Binding Session.HasSelectedProject, Converter={StaticResource InverseBoolToVisibility}}" />
                    <Grid Margin="0,12,0,0" Visibility="{Binding Session.HasSelectedProject, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Total tasks" Style="{StaticResource Metric}" />
                            <TextBlock Text="Completed" Style="{StaticResource Metric}" />
                            <TextBlock Text="Open" Style="{StaticResource Metric}" />
                            <TextBlock Text="Completion rate" Style="{StaticResource Metric}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding ProjectReport.TotalTasks}" Style="{StaticResource MetricValue}" />
                            <TextBlock Text="{Binding ProjectReport.CompletedTasks}" Style="{StaticResource MetricValue}" />
                            <TextBlock Text="{Binding ProjectReport.OpenTasks}" Style="{StaticResource MetricValue}" />
                            <TextBlock Text="{Binding ProjectReport.CompletionRate, StringFormat='{}{0:P0}'}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="{Binding Session.CurrentUserName, StringFormat='Your productivity — {0}'}" Style="{StaticResource H2}" />
                    <TextBlock Text="Sign in to see your productivity." Style="{StaticResource Muted}" Margin="0,8,0,0"
                               Visibility="{Binding Session.IsLoggedIn, Converter={StaticResource InverseBoolToVisibility}}" />
                    <Grid Margin="0,12,0,0" Visibility="{Binding Session.IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Assigned tasks" Style="{StaticResource Metric}" />
                            <TextBlock Text="Completed" Style="{StaticResource Metric}" />
                            <TextBlock Text="Points" Style="{StaticResource Metric}" />
                            <TextBlock Text="Completion rate" Style="{StaticResource Metric}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding UserProductivity.AssignedTasks}" Style="{StaticResource MetricValue}" />
                            <TextBlock Text="{Binding UserProductivity.CompletedTasks}" Style="{StaticResource MetricValue}" />
                            <TextBlock Text="{Binding UserProductivity.Points}" Style="{StaticResource MetricValue}" />
                            <TextBlock Text="{Binding UserProductivity.CompletionRate, StringFormat='{}{0:P0}'}" Style="{StaticResource MetricValue}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
