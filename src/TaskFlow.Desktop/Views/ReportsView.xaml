<UserControl x:Class="TaskFlow.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:TaskFlow.Desktop.Controls"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="860" d:DesignHeight="460">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4">
            <ctrl:CardHeader Title="Reports" ActionCommand="{Binding RefreshCommand}"
                             Margin="{StaticResource SectionMargin}" />

            <ctrl:LabeledField Label="Project" Width="{StaticResource FormColumnWidth}" HorizontalAlignment="Left">
                <ComboBox ItemsSource="{Binding ProjectSelection.Projects}"
                          SelectedItem="{Binding ProjectSelection.Selected}" DisplayMemberPath="Name" />
            </ctrl:LabeledField>

            <!-- Project statistics -->
            <TextBlock Text="{Binding Session.SelectedProjectName, StringFormat='Project — {0}'}"
                       Style="{StaticResource H2}" Margin="0,18,0,0" />
            <TextBlock Text="Select a project to see its statistics." Style="{StaticResource Muted}" Margin="0,8,0,0"
                       Visibility="{Binding Session.HasSelectedProject, Converter={StaticResource InverseBoolToVisibility}}" />
            <UniformGrid Columns="4" Margin="0,8,0,0"
                         Visibility="{Binding Session.HasSelectedProject, Converter={StaticResource BoolToVisibility}}">
                <ctrl:StatCard Caption="Total tasks" Value="{Binding ProjectReport.TotalTasks}"
                               Accent="{StaticResource PrimaryBrush}" />
                <ctrl:StatCard Caption="Completed" Value="{Binding ProjectReport.CompletedTasks}"
                               Accent="{StaticResource SuccessBrush}" />
                <ctrl:StatCard Caption="Open" Value="{Binding ProjectReport.OpenTasks}"
                               Accent="{StaticResource WarnBrush}" />
                <ctrl:StatCard Caption="Completion rate" Accent="{StaticResource SuccessBrush}"
                               Value="{Binding ProjectReport.CompletionRate, StringFormat='{}{0:P0}'}">
                    <ProgressBar Style="{StaticResource StatProgress}" Value="{Binding ProjectReport.CompletionRate}"
                                 Foreground="{StaticResource SuccessBrush}" />
                </ctrl:StatCard>
            </UniformGrid>

            <!-- User productivity -->
            <TextBlock Text="{Binding Session.CurrentUserName, StringFormat='Your productivity — {0}'}"
                       Style="{StaticResource H2}" Margin="0,20,0,0" />
            <TextBlock Text="Sign in to see your productivity." Style="{StaticResource Muted}" Margin="0,8,0,0"
                       Visibility="{Binding Session.IsLoggedIn, Converter={StaticResource InverseBoolToVisibility}}" />
            <UniformGrid Columns="4" Margin="0,8,0,0"
                         Visibility="{Binding Session.IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
                <ctrl:StatCard Caption="Assigned tasks" Value="{Binding UserProductivity.AssignedTasks}"
                               Accent="{StaticResource PrimaryBrush}" />
                <ctrl:StatCard Caption="Completed" Value="{Binding UserProductivity.CompletedTasks}"
                               Accent="{StaticResource SuccessBrush}" />
                <ctrl:StatCard Caption="Points" Value="{Binding UserProductivity.Points}"
                               Accent="{StaticResource WarnBrush}" />
                <ctrl:StatCard Caption="Completion rate" Accent="{StaticResource PrimaryBrush}"
                               Value="{Binding UserProductivity.CompletionRate, StringFormat='{}{0:P0}'}">
                    <ProgressBar Style="{StaticResource StatProgress}" Value="{Binding UserProductivity.CompletionRate}" />
                </ctrl:StatCard>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
