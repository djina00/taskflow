<UserControl x:Class="TaskFlow.Desktop.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="860" d:DesignHeight="460">
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="New task" Style="{StaticResource H2}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,0"
                           Text="{Binding Session.SelectedProjectName, StringFormat='Project: {0}'}"
                           Visibility="{Binding Session.HasSelectedProject, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Text="Select a project on the Projects tab first." Style="{StaticResource Muted}" Margin="0,2,0,0"
                           Visibility="{Binding Session.HasSelectedProject, Converter={StaticResource InverseBoolToVisibility}}" />

                <TextBlock Text="Title" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Description" Style="{StaticResource FieldLabel}" />
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="52" VerticalScrollBarVisibility="Auto" />
                <TextBlock Text="Priority" Style="{StaticResource FieldLabel}" />
                <ComboBox SelectedValue="{Binding Priority}" SelectedValuePath="Content">
                    <ComboBoxItem Content="Low" />
                    <ComboBoxItem Content="Medium" />
                    <ComboBoxItem Content="High" />
                </ComboBox>
                <Button Content="Create task" Style="{StaticResource PrimaryButton}"
                        Command="{Binding CreateCommand}" Margin="0,16,0,0" />
                <TextBlock Text="{Binding Status}" Style="{StaticResource StatusText}" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16,14">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="Tasks" Style="{StaticResource H2}" VerticalAlignment="Center" />
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" />
                </DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Button Content="Assign to me" Style="{StaticResource PrimaryButton}"
                            Command="{Binding AssignToMeCommand}" Margin="0,0,8,0" />
                    <Button Content="Start" Command="{Binding StartCommand}" Margin="0,0,8,0" />
                    <Button Content="Complete" Command="{Binding CompleteCommand}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="*" />
                        <DataGridTextColumn Header="PRIORITY" Binding="{Binding Priority}" Width="90" />
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="ASSIGNEE" Binding="{Binding AssigneeId}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
