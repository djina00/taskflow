<UserControl x:Class="TaskFlow.Desktop.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:TaskFlow.Desktop.Controls"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignWidth="860" d:DesignHeight="460">
    <Grid Margin="4">
        <Border Style="{StaticResource Card}" Padding="16,14">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="{StaticResource SectionMargin}">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                        <Button Content="+  Add task" Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddCommand}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Tasks" Style="{StaticResource H2}" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <TextBlock Text="Project" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <ComboBox Width="200" ItemsSource="{Binding ProjectSelection.Projects}"
                                  SelectedItem="{Binding ProjectSelection.Selected}" DisplayMemberPath="Name" />
                    </StackPanel>
                </DockPanel>
                <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Muted}" Margin="2,8,0,0"
                           Text="Double-click a task to open it." />
                <DataGrid ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenSelectedCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TITLE" Binding="{Binding Task.Title}" Width="*" />
                        <DataGridTextColumn Header="PRIORITY" Binding="{Binding Task.Priority}" Width="80" />
                        <DataGridTemplateColumn Header="STATUS" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ctrl:StatusBadge Status="{Binding Task.Status}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="REPORTER" Binding="{Binding ReporterName}" Width="110" />
                        <DataGridTextColumn Header="ASSIGNEE" Binding="{Binding AssigneeName}" Width="110" />
                        <DataGridTemplateColumn Header="" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RowDeleteButton}"
                                            HorizontalAlignment="Center"
                                            ToolTip="Delete this task"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
