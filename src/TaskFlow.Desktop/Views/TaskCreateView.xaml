<UserControl x:Class="TaskFlow.Desktop.Views.TaskCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:TaskFlow.Desktop.Controls">
    <StackPanel Width="400">
        <TextBlock Text="New task" Style="{StaticResource H2}" />

        <Border Style="{StaticResource Divider}" />

        <ctrl:LabeledField Label="Project">
            <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}" DisplayMemberPath="Name" />
        </ctrl:LabeledField>
        <ctrl:LabeledField Label="Title">
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
        </ctrl:LabeledField>
        <ctrl:LabeledField Label="Description">
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Height="64" VerticalScrollBarVisibility="Auto" />
        </ctrl:LabeledField>
        <ctrl:LabeledField Label="Priority">
            <ComboBox SelectedValue="{Binding Priority}" SelectedValuePath="Content">
                <ComboBoxItem Content="Low" />
                <ComboBoxItem Content="Medium" />
                <ComboBoxItem Content="High" />
            </ComboBox>
        </ctrl:LabeledField>

        <Border Style="{StaticResource Divider}" />

        <DockPanel LastChildFill="False">
            <Button DockPanel.Dock="Right" Content="Cancel" Command="{Binding CloseCommand}" Margin="8,0,0,0" />
            <Button DockPanel.Dock="Right" Content="Create task" Style="{StaticResource PrimaryButton}"
                    Command="{Binding CreateCommand}" />
        </DockPanel>
        <TextBlock Text="{Binding Status}" Style="{StaticResource StatusText}" Foreground="{StaticResource ErrorBrush}" />
    </StackPanel>
</UserControl>
